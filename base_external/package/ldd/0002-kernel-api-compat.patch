--- /dev/null
+++ b/include/kernel_compat.h
@@ -0,0 +1,34 @@
+#ifndef _KERNEL_COMPAT_H
+#define _KERNEL_COMPAT_H
+
+#include <linux/version.h>
+#include <linux/timer.h>
+#include <linux/fs.h>
+
+/*
+ * Compatibility shims that let the (older) LDD3 example sources build against
+ * modern kernels, without editing every call site. Follows the style of the
+ * existing proc_ops_version.h / access_ok_version.h helpers in this directory.
+ */
+
+/* 6.16: from_timer() renamed to timer_container_of(); del_timer_sync() removed
+ * in favour of timer_delete_sync(). */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 16, 0)
+#ifndef from_timer
+#define from_timer(var, callback_timer, timer_fieldname) \
+	timer_container_of(var, callback_timer, timer_fieldname)
+#endif
+#ifndef del_timer_sync
+#define del_timer_sync(t) timer_delete_sync(t)
+#endif
+#endif /* >= 6.16.0 */
+
+/* 6.12: no_llseek() was removed. It returned -ESPIPE ("not seekable"); the
+ * closest drop-in that keeps these example drivers building is noop_llseek. */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 12, 0)
+#ifndef no_llseek
+#define no_llseek noop_llseek
+#endif
+#endif /* >= 6.12.0 */
+
+#endif /* _KERNEL_COMPAT_H */
